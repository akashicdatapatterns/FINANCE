# Copy this file to .env and set real values before running the app.
# Do not commit your .env file to GitHub.

# Login passwords
ADMIN_PASSWORD=your_admin_password
PERSONAL_PASSWORD=your_personal_password
BUSINESS_PASSWORD=your_business_password

# Database connection
# Local SQLite (default — data is lost when the container restarts on cloud hosts):
# DATABASE_URL=finance.db
#
# For persistent cloud deployments, use a PostgreSQL connection string:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
#
# Streamlit Cloud: add the DATABASE_URL secret in the app settings.
# Free PostgreSQL providers: Supabase (supabase.com), Neon (neon.tech), Railway (railway.app)
# DATABASE_URL=
